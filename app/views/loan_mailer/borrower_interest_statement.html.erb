<h2 style="font-size: 18px; font-weight: 600; color: #111827; margin: 0 0 8px 0;">
  Your <%= @year %> Interest Statement
</h2>

<p style="font-size: 14px; color: #6b7280; margin: 0 0 24px 0; line-height: 1.6;">
  <%= @borrower.name %>,
</p>

<p style="font-size: 14px; color: #6b7280; margin: 0 0 16px 0; line-height: 1.6;">
  Attached is your annual interest statement for <%= @year %> from <%= @business_name.presence || "your lender" %>.
</p>

<p style="font-size: 14px; color: #6b7280; margin: 0 0 16px 0; line-height: 1.6;">
  This statement summarizes the interest and principal payments made on your loan(s) during the year.
  Please retain this for your tax records.
</p>

<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 24px;">
  <tr>
    <td style="background-color: #f0fdf4; border: 1px solid #a7f3d0; border-radius: 8px; padding: 16px; text-align: center;">
      <p style="font-size: 12px; font-weight: 600; color: #059669; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 4px 0;">
        Attachment
      </p>
      <p style="font-size: 14px; font-weight: 600; color: #065f46; margin: 0;">
        interest_statement_<%= @year %>.pdf
      </p>
    </td>
  </tr>
</table>

<p style="font-size: 14px; color: #6b7280; margin: 0 0 8px 0; line-height: 1.6;">
  If you have questions about this statement, please contact
  <strong><%= @user.email %></strong>.
</p>

<p style="font-size: 14px; color: #111827; font-weight: 500; margin: 24px 0 0 0;">
  <%= @business_name.presence || "Your Lender" %>
</p>

<h2 style="font-size: 18px; font-weight: 600; color: #111827; margin: 0 0 8px 0;">
  Payment Reminder
</h2>
<p style="font-size: 14px; color: #6b7280; margin: 0 0 24px 0; line-height: 1.6;">
  This is a friendly reminder that a payment is due soon on your loan.
</p>

<!-- Amount Due Card -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 24px;">
  <tr>
    <td style="background-color: #ecfdf5; border: 1px solid #a7f3d0; border-radius: 8px; padding: 20px; text-align: center;">
      <p style="font-size: 12px; font-weight: 600; color: #059669; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 4px 0;">
        Amount Due
      </p>
      <p style="font-size: 32px; font-weight: 700; color: #065f46; margin: 0; letter-spacing: -0.025em;">
        $<%= number_with_precision(@amount_due, precision: 2, delimiter: ",") %>
      </p>
      <p style="font-size: 13px; color: #6b7280; margin: 8px 0 0 0;">
        Due on <strong><%= @due_date.strftime("%B %d, %Y") %></strong>
      </p>
    </td>
  </tr>
</table>

<!-- Loan Details -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 24px;">
  <tr>
    <td style="padding: 12px 0; border-bottom: 1px solid #f3f4f6;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Borrower</td>
          <td align="right" style="font-size: 13px; color: #111827; font-weight: 500;"><%= @loan.borrower_name %></td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 0; border-bottom: 1px solid #f3f4f6;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Payment #</td>
          <td align="right" style="font-size: 13px; color: #111827; font-weight: 500;"><%= @payment_number %> of <%= @loan.term_months %></td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 0; border-bottom: 1px solid #f3f4f6;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Remaining Balance</td>
          <td align="right" style="font-size: 13px; color: #111827; font-weight: 500;">$<%= number_with_precision(@remaining_balance, precision: 2, delimiter: ",") %></td>
        </tr>
      </table>
    </td>
  </tr>
  <% if @expected %>
  <tr>
    <td style="padding: 12px 0;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Breakdown</td>
          <td align="right" style="font-size: 13px; color: #111827; font-weight: 500;">
            $<%= number_with_precision(@expected[:principal_portion].to_f, precision: 2, delimiter: ",") %> principal +
            $<%= number_with_precision(@expected[:interest_portion].to_f, precision: 2, delimiter: ",") %> interest
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <% end %>
</table>

<p style="font-size: 13px; color: #6b7280; line-height: 1.6; margin: 0;">
  Please ensure your payment is made on or before the due date. If you have already made this payment, please disregard this reminder.
</p>

<h2 style="font-size: 18px; font-weight: 600; color: #111827; margin: 0 0 8px 0;">
  Payment Overdue Notice
</h2>
<p style="font-size: 14px; color: #6b7280; margin: 0 0 24px 0; line-height: 1.6;">
  Our records indicate that a payment on your loan is past due. Please arrange payment at your earliest convenience.
</p>

<!-- Overdue Alert -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 24px;">
  <tr>
    <td style="background-color: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 20px; text-align: center;">
      <p style="font-size: 12px; font-weight: 600; color: #dc2626; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 4px 0;">
        Payment Overdue
      </p>
      <p style="font-size: 32px; font-weight: 700; color: #991b1b; margin: 0; letter-spacing: -0.025em;">
        $<%= number_with_precision(@amount_due, precision: 2, delimiter: ",") %>
      </p>
      <p style="font-size: 13px; color: #991b1b; margin: 8px 0 0 0;">
        <strong><%= @days_overdue %> day<%= 's' if @days_overdue != 1 %></strong> past due
        &mdash; Originally due <%= @due_date&.strftime("%B %d, %Y") || "N/A" %>
      </p>
    </td>
  </tr>
</table>

<!-- Loan Details -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 24px;">
  <tr>
    <td style="padding: 12px 0; border-bottom: 1px solid #f3f4f6;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Borrower</td>
          <td align="right" style="font-size: 13px; color: #111827; font-weight: 500;"><%= @loan.display_borrower_name %></td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 0; border-bottom: 1px solid #f3f4f6;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Original Loan Amount</td>
          <td align="right" style="font-size: 13px; color: #111827; font-weight: 500;">$<%= number_with_precision(@loan.principal.to_f, precision: 2, delimiter: ",") %></td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 0;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Outstanding Balance</td>
          <td align="right" style="font-size: 13px; color: #111827; font-weight: 500;">$<%= number_with_precision(@remaining_balance, precision: 2, delimiter: ",") %></td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<p style="font-size: 13px; color: #374151; line-height: 1.6; margin: 0 0 16px 0; font-weight: 500;">
  Please make your payment as soon as possible to avoid any additional fees or impact to your loan standing.
</p>

<p style="font-size: 13px; color: #6b7280; line-height: 1.6; margin: 0;">
  If you have already submitted this payment, please allow processing time and disregard this notice.
  For questions or to discuss payment arrangements, please contact your lender directly.
</p>

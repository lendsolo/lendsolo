<h2 style="font-size: 18px; font-weight: 600; color: #111827; margin: 0 0 8px 0;">
  Payment Received
</h2>
<p style="font-size: 14px; color: #6b7280; margin: 0 0 24px 0; line-height: 1.6;">
  Thank you for your payment. Here is your receipt for your records.
</p>

<!-- Payment Confirmation -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 24px;">
  <tr>
    <td style="background-color: #ecfdf5; border: 1px solid #a7f3d0; border-radius: 8px; padding: 20px; text-align: center;">
      <p style="font-size: 12px; font-weight: 600; color: #059669; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 4px 0;">
        Payment Confirmed
      </p>
      <p style="font-size: 32px; font-weight: 700; color: #065f46; margin: 0; letter-spacing: -0.025em;">
        $<%= number_with_precision(@payment.amount.to_f, precision: 2, delimiter: ",") %>
      </p>
      <p style="font-size: 13px; color: #6b7280; margin: 8px 0 0 0;">
        Received on <strong><%= @payment.date.strftime("%B %d, %Y") %></strong>
      </p>
    </td>
  </tr>
</table>

<!-- Payment Breakdown -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 24px;">
  <tr>
    <td style="padding: 12px 0; border-bottom: 1px solid #f3f4f6;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Borrower</td>
          <td align="right" style="font-size: 13px; color: #111827; font-weight: 500;"><%= @loan.borrower_name %></td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 0; border-bottom: 1px solid #f3f4f6;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Principal Portion</td>
          <td align="right" style="font-size: 13px; color: #111827; font-weight: 500;">$<%= number_with_precision(@payment.principal_portion.to_f, precision: 2, delimiter: ",") %></td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 0; border-bottom: 1px solid #f3f4f6;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Interest Portion</td>
          <td align="right" style="font-size: 13px; color: #111827; font-weight: 500;">$<%= number_with_precision(@payment.interest_portion.to_f, precision: 2, delimiter: ",") %></td>
        </tr>
      </table>
    </td>
  </tr>
  <% if @payment.late_fee.to_f > 0 %>
  <tr>
    <td style="padding: 12px 0; border-bottom: 1px solid #f3f4f6;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Late Fee</td>
          <td align="right" style="font-size: 13px; color: #dc2626; font-weight: 500;">$<%= number_with_precision(@payment.late_fee.to_f, precision: 2, delimiter: ",") %></td>
        </tr>
      </table>
    </td>
  </tr>
  <% end %>
  <tr>
    <td style="padding: 12px 0; border-bottom: 1px solid #f3f4f6;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Remaining Balance</td>
          <td align="right" style="font-size: 13px; color: #111827; font-weight: 600;">$<%= number_with_precision(@remaining_balance, precision: 2, delimiter: ",") %></td>
        </tr>
      </table>
    </td>
  </tr>
  <% if @next_due %>
  <tr>
    <td style="padding: 12px 0;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td style="font-size: 13px; color: #6b7280;">Next Payment Due</td>
          <td align="right" style="font-size: 13px; color: #111827; font-weight: 500;"><%= @next_due.strftime("%B %d, %Y") %></td>
        </tr>
      </table>
    </td>
  </tr>
  <% end %>
</table>

<% if @payment.note.present? %>
<p style="font-size: 13px; color: #6b7280; line-height: 1.6; margin: 0 0 16px 0;">
  <strong>Note:</strong> <%= @payment.note %>
</p>
<% end %>

<% if @loan.paid_off? %>
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 16px;">
  <tr>
    <td style="background-color: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 16px; text-align: center;">
      <p style="font-size: 14px; font-weight: 600; color: #166534; margin: 0;">
        This loan has been paid in full. Thank you!
      </p>
    </td>
  </tr>
</table>
<% end %>

<p style="font-size: 12px; color: #9ca3af; margin: 0;">
  Please retain this receipt for your records.
</p>
